+fn hosted_image_generation_model_visible(turn_context: &TurnContext) -> bool {
+    let provider = turn_context.provider.info();
+    let has_configured_actor_authorization =
+        provider.http_headers.as_ref().is_some_and(|headers| {
+            headers.iter().any(|(name, value)| {
+                name.eq_ignore_ascii_case("x-openai-actor-authorization")
+                    && !value.trim().is_empty()
+            })
+        });
+    let custom_provider =
+        !provider.is_openai() || provider.base_url.is_some() || has_configured_actor_authorization;
+
+    image_generation_runtime_enabled(turn_context)
+        && custom_provider
+        && turn_context
+            .config
+            .features
+            .get()
+            .enabled(Feature::ImageGeneration)
+}
